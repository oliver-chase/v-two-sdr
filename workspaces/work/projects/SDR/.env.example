# =============================================================================
# SDR System — Environment Variables
# Copy this to .env and fill in real values. Never commit .env.
# =============================================================================

# ---------------------------------------------------------------------------
# Email Sending (Gmail SMTP)
# ---------------------------------------------------------------------------
# Gmail address used to send outreach
GMAIL_USER=oliver@vtwo.co

# Gmail App Password (not your account password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2FA enabled on Gmail account
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# BCC address for your own records (every outbound email BCCs here)
BCC_EMAIL=oliver+sdr@vtwo.co

# Display name in From field
SENDER_NAME=Oliver Chase

# Daily send cap (start low at ramp: 10-15, scale to 25 max)
MAX_DAILY_SENDS=15

# Delay between individual sends in ms (30s default = 2/min max)
SEND_DELAY_MS=30000

# ---------------------------------------------------------------------------
# Google Sheets
# ---------------------------------------------------------------------------
# The spreadsheet ID from the URL: docs.google.com/spreadsheets/d/SHEET_ID/
GOOGLE_SHEET_ID=

# Path to service account JSON (relative to SDR project root)
GOOGLE_CREDENTIALS_PATH=./secrets/google-credentials.json

# Sheet tab names (defaults shown)
GOOGLE_SHEET_NAME=Prospects
GOOGLE_TEMPLATES_SHEET=Templates
GOOGLE_OPTOUTS_SHEET=OptOuts

# ---------------------------------------------------------------------------
# Email Enrichment APIs
# ---------------------------------------------------------------------------
# Hunter.io — finds emails from domain/name
# Free: 25 searches/mo | Paid: $49/mo for 500
HUNTER_API_KEY=

# NeverBounce — validates email deliverability
# Free: 1000 credits | Paid: $8/1000
NEVERBOUNCE_API_KEY=

# ---------------------------------------------------------------------------
# AI Model Routing (used by OpenClaw)
# ---------------------------------------------------------------------------
# Anthropic API key (primary — Claude Haiku 4.5)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenRouter paid key (fallback if Anthropic quota exceeded)
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# or-free key already set in OpenClaw models.json (last resort free models)
