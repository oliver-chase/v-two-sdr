# =============================================================================
# SDR System — Environment Variables
# Copy this to .env and fill in real values. Never commit .env.
# These same variable names are used as GitHub Secrets in saturdaythings/v-two-sdr
# =============================================================================

# ---------------------------------------------------------------------------
# Email Sending — Outlook / Microsoft 365 (oliver@vtwo.co)
# ---------------------------------------------------------------------------
# Your Outlook email address
OUTLOOK_USER=oliver@vtwo.co

# Your Outlook password (or App Password if MFA is enabled)
# If MFA is on: generate an App Password at account.microsoft.com/security
OUTLOOK_PASSWORD=your-outlook-password-here

# BCC address for your own records (every outbound email BCCs here)
BCC_EMAIL=oliver+sdr@vtwo.co

# Display name in From field
SENDER_NAME=Oliver Chase

# Daily send cap (start at 15, scale to 25 max once warmed)
MAX_DAILY_SENDS=15

# Delay between individual sends in ms (30s = ~2/min, safe for cold outreach)
SEND_DELAY_MS=30000

# ---------------------------------------------------------------------------
# Google Sheets — V.Two SDR - Master Lead Repository
# ---------------------------------------------------------------------------
# Sheet ID from the Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/{GOOGLE_SHEET_ID}/edit
GOOGLE_SHEET_ID=your-sheet-id-here

# Google Cloud API key restricted to Sheets API (read-only access)
# The sheet MUST be shared: "Anyone with the link can view"
# Create at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_API_KEY=your-google-api-key-here

# Tab name within the spreadsheet (default: "Leads")
GOOGLE_SHEET_NAME=Leads

# ---------------------------------------------------------------------------
# AI Template Generation — Anthropic Claude Haiku
# ---------------------------------------------------------------------------
# Used to generate soft-custom email templates grouped by prospect signals
# Haiku is fast and cheap — template generation costs <$0.01 per batch
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional fallback: OpenRouter (paid key)
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Email Enrichment (optional — add later if needed)
# ---------------------------------------------------------------------------
# Hunter.io — find emails from domain/name
HUNTER_API_KEY=

# NeverBounce — validate email deliverability
NEVERBOUNCE_API_KEY=
