# =============================================================================
# SDR System — Environment Variables
# Copy this to .env and fill in real values. Never commit .env.
# All secrets must be set as GitHub Secrets in saturdaythings/v-two-sdr
# =============================================================================

# ---------------------------------------------------------------------------
# Outlook / Microsoft 365 Email Sending — OAuth (Microsoft Graph API)
# ---------------------------------------------------------------------------
# Azure tenant ID from Microsoft Entra ID
OUTLOOK_TENANT_ID=your-azure-tenant-id

# Azure app registration client ID
OUTLOOK_CLIENT_ID=your-azure-app-client-id

# Azure app registration client secret
OUTLOOK_CLIENT_SECRET=your-azure-app-secret

# Display name in From field
SENDER_NAME=Oliver Chase

# BCC address for your own records (every outbound email BCCs here)
BCC_EMAIL=oliver@vtwo.co

# Daily send cap (start at 15, scale to 25 max once warmed)
MAX_DAILY_SENDS=15

# Delay between individual sends in ms (30s = ~2/min, safe for cold outreach)
SEND_DELAY_MS=30000

# ---------------------------------------------------------------------------
# Google Sheets — Master Lead Repository
# ---------------------------------------------------------------------------
# Sheet ID from the Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/{GOOGLE_SHEET_ID}/edit
GOOGLE_SHEET_ID=your-sheet-id

# Service account email with write access to the sheet
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Service account private key (include \n for line breaks)
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ---------------------------------------------------------------------------
# APIs — Enrichment and Verification
# ---------------------------------------------------------------------------
# Abstract API — timezone lookup for prospect analysis
ABSTRACT_API_KEY=your-abstract-api-key

# Hunter.io — email verification via /v2/email-verifier endpoint
HUNTER_IO_API_KEY=your-hunter-io-api-key

# ---------------------------------------------------------------------------
# LLM — Email Drafting (3-tier fallback)
# ---------------------------------------------------------------------------
# Tier 1 (preferred): Anthropic Claude Haiku — fastest, best quality
# Get key: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# Tier 2 (fallback): OpenRouter paid account — uses gpt-4o-mini if Anthropic fails
# Get key: openrouter.ai/settings/keys
OPENROUTER_API_KEY=your-openrouter-paid-key

# Tier 3 (last resort): OpenRouter free models — slower, may queue
OPENROUTER_FREE_KEY=your-openrouter-free-key
