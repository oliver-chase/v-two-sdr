#!/bin/bash
# Pre-commit hook: Prevent hardcoded file paths
# Install: cp pre-commit-paths .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Blocks: Hardcoded /Users/oliver paths, /home paths, absolute paths specific to developer machine

set -e

PATTERNS=(
    '/Users/[^/]+/'        # macOS home directory paths
    '/home/[^/]+/'         # Linux home directory paths
    'C:\\Users\\'          # Windows paths
    '/opt/local/'          # Development-specific paths
)

EXITCODE=0

echo "🔍 Checking for hardcoded file paths..."

for pattern in "${PATTERNS[@]}"; do
    if git diff --cached | grep -E "$pattern" --color=never; then
        echo "❌ ABORT: Hardcoded file path detected: $pattern"
        EXITCODE=1
    fi
done

if [ $EXITCODE -ne 0 ]; then
    echo ""
    echo "🛑 Security violation: Don't commit hardcoded file paths!"
    echo "   Use relative paths instead: './data/file.json' not '/Users/oliver/project/data/file.json'"
    echo ""
    exit 1
fi

echo "✅ No hardcoded paths detected. Good to commit."
exit 0
