#!/bin/bash
# Pre-commit hook: Prevent secrets from being committed
# Install: cp pre-commit-secrets .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Blocks: API keys, passwords, tokens, AWS credentials, private keys

set -e

PATTERNS=(
    'api[_-]?key'
    'secret[_-]?key'
    'password'
    'Bearer [A-Za-z0-9\._\-]+'
    'aws_access_key'
    'aws_secret_access_key'
    'private[_-]?key'
    'token.*='
    '-----BEGIN'
    'AKIA[0-9A-Z]{16}'
)

EXITCODE=0

echo "🔍 Checking for secrets in staged changes..."

for pattern in "${PATTERNS[@]}"; do
    if git diff --cached | grep -E "$pattern" --color=never; then
        echo "❌ ABORT: Potential secrets detected matching pattern: $pattern"
        EXITCODE=1
    fi
done

if [ $EXITCODE -ne 0 ]; then
    echo ""
    echo "🛑 Security violation: Don't commit secrets directly!"
    echo "   Use secret-portal instead: https://github.com/openclaw/skills/tree/main/skills/awlevin/secret-portal"
    echo ""
    echo "   Or manually override:"
    echo "   git commit --no-verify  # NOT RECOMMENDED - you're on your own"
    exit 1
fi

echo "✅ No secrets detected. Good to commit."
exit 0
