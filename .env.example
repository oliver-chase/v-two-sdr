# SDR Environment — Copy to .env, fill values. Never commit .env.
# All secrets also live in GitHub Actions (saturdaythings/v-two-sdr → Settings → Secrets).

# ── Outlook / Microsoft Graph ──────────────────────────────────────────────────
# Azure app registration for oliver@vtwo.co. Used by mailer.js and approval-email.js.
# Grant type: client_credentials. Scope: https://graph.microsoft.com/Mail.Send
OUTLOOK_TENANT_ID=your-azure-tenant-id
OUTLOOK_CLIENT_ID=your-azure-app-client-id
OUTLOOK_CLIENT_SECRET=your-azure-app-secret

# IMAP password for inbox-monitor.js (basic auth, outlook.office365.com:993).
# This is the account password, not the OAuth secret above.
OUTLOOK_PASSWORD=your-outlook-account-password

# Email sender display name and daily send limits
SENDER_NAME=Oliver Chase
BCC_EMAIL=oliver@vtwo.co
MAX_DAILY_SENDS=15
SEND_DELAY_MS=30000

# ── Google Sheets ──────────────────────────────────────────────────────────────
# Service account credentials. Used for both reads and writes (no API key needed).
# See docs/GOOGLE_CLOUD_SETUP.md for setup steps.
GOOGLE_SHEET_ID=your-sheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Multiline PEM key — load via: node -r dotenv/config (NOT source .env)
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ── LLM ───────────────────────────────────────────────────────────────────────
# Used by draft.js for batched email generation. Falls back to static templates if unset.
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── GitHub Actions ────────────────────────────────────────────────────────────
# Personal access token scoped to actions:write only.
# Used by approval-email.js to embed approve/reject curl commands in the digest email,
# and by approval-handler.yml to trigger send-approved.yml on approval.
SDR_PAT=your-github-pat-actions-write-only

# ── APIs ──────────────────────────────────────────────────────────────────────
ABSTRACT_API_KEY=your-abstract-api-key
HUNTER_IO_API_KEY=your-hunter-io-api-key
SERPER_API_KEY=your-serper-api-key
